# Pulse — Environment Variables
# Copy this file to .env.local and fill in your values

# Required: Your Anthropic API key (for AI assistant, voice parsing, document scanning, gift suggestions)
# Get one at https://console.anthropic.com/
# IMPORTANT: Do NOT add NEXT_PUBLIC_ prefix — this key must stay server-side only
ANTHROPIC_API_KEY=your_api_key_here
